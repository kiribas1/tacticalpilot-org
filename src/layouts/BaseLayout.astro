---
interface Props {
  title: string;
  description: string;
  lang: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const { title, description, lang, canonicalUrl, ogImage } = Astro.props;
const currentPath = Astro.url.pathname;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';
const canonical = canonicalUrl || `${siteUrl}${currentPath}`;
const dir = lang === 'ar' ? 'rtl' : 'ltr';

const locales = ['en', 'es', 'zh', 'ru', 'pt', 'ar'];
const langNames: Record<string, string> = {
  en: 'English',
  es: 'Español',
  zh: '中文',
  ru: 'Русский',
  pt: 'Português',
  ar: 'العربية',
};
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" content="#0b0c10" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="TacticalPilot" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${siteUrl}/images/logo.webp`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="TacticalPilot" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/images/logo.webp`} />

    <!-- Hreflang -->
    {locales.map((loc) => {
      const path = currentPath.replace(`/${lang}/`, `/${loc}/`);
      return <link rel="alternate" hreflang={loc} href={`${siteUrl}${path}`} />;
    })}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/`} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": `${siteUrl}/#website`,
          "url": `${siteUrl}/`,
          "name": "TacticalPilot",
          "inLanguage": lang
        },
        {
          "@type": "Organization",
          "@id": `${siteUrl}/#org`,
          "name": "TacticalPilot",
          "url": `${siteUrl}/`,
          "logo": `${siteUrl}/images/logo.webp`
        }
      ]
    })} />

    <!-- Favicons -->
    <link rel="apple-touch-icon" sizes="180x180" href="/images/favicons/apple-icon-180x180.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicons/favicon-16x16.png" />
    <link rel="manifest" href="/images/favicons/manifest.json" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico?v=2" />

    <!-- Fonts + CSS libs -->
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Jura:wght@300..700&display=swap" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" rel="stylesheet" />

    <!-- Google AdSense -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2701690512336282"
      crossorigin="anonymous"
    ></script>

    <style is:global>
      :root{
        --tp-bg: #0b0c10;
        --tp-card: rgba(255,255,255,.06);
        --tp-border: rgba(255,255,255,.14);
        --tp-text: rgba(255,255,255,.86);
        --tp-muted: rgba(255,255,255,.62);
      }

      body{
        font-family: 'Jura', sans-serif;
        background: var(--tp-bg);
        margin: 0;
        padding: 0;
      }

      /* ---- Hero ---- */
      .tp-hero{
        color: #fff;
        border-bottom: 1px solid rgba(255,255,255,.08);
      }
      .tp-hero-bg{
        position:absolute; inset:-2px;
        background:
          radial-gradient(800px 400px at 20% 20%, rgba(80, 120, 255, .35), transparent 60%),
          radial-gradient(600px 380px at 80% 30%, rgba(170, 60, 255, .28), transparent 65%),
          radial-gradient(700px 500px at 55% 95%, rgba(40, 220, 160, .18), transparent 55%),
          linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,0));
        filter: saturate(1.05);
        pointer-events:none;
      }
      .tp-lead{
        color: var(--tp-text);
        max-width: 54ch;
      }
      .tp-logo{
        border-radius: 14px;
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.16);
        padding: 10px;
      }
      .tp-pill{
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.14);
        border-radius: 999px;
        padding: 8px 12px;
        color: rgba(255,255,255,.92);
        backdrop-filter: blur(10px);
      }
      .tp-dot{
        width: 8px; height: 8px; border-radius: 50%;
        background: #4cffb5;
        box-shadow: 0 0 0 3px rgba(76,255,181,.16);
      }
      .tp-divider{
        width: 1px; height: 16px;
        background: rgba(255,255,255,.18);
        display:inline-block;
      }
      .tp-badge{
        background: rgba(255,255,255,.08) !important;
        border: 1px solid rgba(255,255,255,.14) !important;
        color: rgba(255,255,255,.92) !important;
        padding: .55rem .7rem;
        border-radius: 999px;
      }
      .tp-btn{
        border-radius: 14px;
        padding: .85rem 1.05rem;
        box-shadow: 0 10px 30px rgba(0,0,0,.25);
      }
      .tp-btn-outline{
        border-radius: 14px;
        border-color: rgba(255,255,255,.35);
        color: rgba(255,255,255,.92);
      }
      .tp-btn-outline:hover{
        border-color: rgba(255,255,255,.55);
        color: #fff;
      }
      .tp-card-glass{
        background: var(--tp-card);
        border: 1px solid var(--tp-border);
        border-radius: 22px;
        box-shadow: 0 18px 60px rgba(0,0,0,.35);
        backdrop-filter: blur(14px);
      }
      .tp-mini{ color: var(--tp-muted); }
      .tp-list li{ margin-bottom: .35rem; }

      /* ---- Light section ---- */
      .tp-light{
        background: #f4f5f7;
        color: #111;
      }
      .tp-feature{
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(0,0,0,.08);
        border-radius: 22px;
        padding: 22px;
        box-shadow: 0 10px 30px rgba(0,0,0,.18);
      }
      .tp-light .tp-feature{
        background: #fff;
      }
      .tp-icon-light{
        width: 44px; height: 44px;
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        background: rgba(0,0,0,.07);
        border: 1px solid rgba(0,0,0,.1);
        color: #111;
        font-size: 1.1rem;
        margin-bottom: 12px;
      }
      .tp-btn-dark{
        border-radius: 14px;
        padding: .85rem 1.05rem;
        background: #111;
        color: #fff;
        border: none;
        box-shadow: 0 10px 30px rgba(0,0,0,.18);
      }
      .tp-btn-dark:hover{ background: #222; color: #fff; }
      .tp-panel{
        background: #fff;
        border: 1px solid rgba(0,0,0,.08);
        border-radius: 22px;
        padding: 22px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
      }
      .tp-cta-light{
        background: #fff;
        border: 1px solid rgba(0,0,0,.08);
        border-radius: 22px;
        box-shadow: 0 10px 30px rgba(0,0,0,.07);
      }
      .tp-footer-licence{
        max-width: 480px;
        margin: 0 auto;
      }

      /* ---- Footer ---- */
      footer.tp-footer{
        background: var(--tp-bg);
        color: var(--tp-text);
      }
      footer.tp-footer a{ color: var(--tp-text); }

      /* ---- Language switcher in navbar ---- */
      .tp-lang-nav{
        background: var(--tp-bg);
        border-bottom: 1px solid rgba(255,255,255,.08);
      }
      .tp-lang-link{
        color: rgba(255,255,255,.55);
        text-decoration: none;
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 0.85rem;
        transition: color .2s, background .2s;
      }
      .tp-lang-link:hover,
      .tp-lang-link.active{
        color: #fff;
        background: rgba(255,255,255,.1);
        text-decoration: none;
      }
    </style>
  </head>

  <body class="d-flex flex-column min-vh-100">

    <!-- Language switcher navbar -->
    <nav class="tp-lang-nav py-2">
      <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2">
        <a class="text-white text-decoration-none fw-semibold" href={`/${lang}/`}>TacticalPilot</a>
        <div class="d-flex gap-1 flex-wrap">
          {locales.map((loc) => {
            const path = currentPath.replace(`/${lang}/`, `/${loc}/`);
            return (
              <a href={path} class={`tp-lang-link${loc === lang ? ' active' : ''}`}>
                {langNames[loc]}
              </a>
            );
          })}
        </div>
      </div>
    </nav>

    <main class="flex-fill">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="tp-footer border-top mt-5">
      <div class="container-xl py-4 small text-light d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
        <div>&copy; 2026 TacticalPilot</div>
        <div class="d-flex gap-3">
          <a class="text-light text-decoration-none" href={`/${lang}/`}>Home</a>
          <a class="text-light text-decoration-none" href="mailto:info@tacticalpilot.org">Contact</a>
        </div>
      </div>

      <div class="container-xl pb-4">
        <div class="mx-auto text-center small text-light opacity-75 tp-footer-licence">
          <small>&copy; 2026 Tactical Pilot. All rights reserved.</small><br />
          <div class="mt-2"><small>
            <div>Address: Noregon - London (KI)</div>
            <div><strong>Licence No.:</strong> KBN-40-000003</div>
            <div class="link-secondary">
              Authority:
              <a href="https://kiribas.org/" target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                Kiribati International Financial Authority (KIFA)
              </a>
            </div>
          </small></div>
        </div>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.min.js"></script>
  </body>
</html>
