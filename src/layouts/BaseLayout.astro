---
interface Props {
  title: string;
  description: string;
  lang: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const { title, description, lang, canonicalUrl, ogImage } = Astro.props;
const currentPath = Astro.url.pathname;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';
const canonical = canonicalUrl || `${siteUrl}${currentPath}`;
const dir = lang === 'ar' ? 'rtl' : 'ltr';

const locales = ['en', 'es', 'zh', 'ru', 'pt', 'ar'];
const langNames: Record<string, string> = {
  en: 'English',
  es: 'Español',
  zh: '中文',
  ru: 'Русский',
  pt: 'Português',
  ar: 'العربية',
};
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Hreflang -->
    {locales.map((loc) => {
      const path = currentPath.replace(`/${lang}/`, `/${loc}/`);
      return <link rel="alternate" hreflang={loc} href={`${siteUrl}${path}`} />;
    })}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/`} />

    <!-- Google AdSense - replace ca-pub-XXXXXXX with your real ID -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2701690512336282"
      crossorigin="anonymous"
    ></script>

    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        line-height: 1.6;
        color: #1a1a2e;
        background: #fafafa;
      }
      a {
        color: #0066cc;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px;
      }
      header {
        background: #1a1a2e;
        color: white;
        padding: 16px 0;
        position: sticky;
        top: 0;
        z-index: 100;
      }
      header .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
      }
      .logo {
        font-size: 1.4rem;
        font-weight: 700;
        color: white;
      }
      .logo:hover {
        text-decoration: none;
      }
      nav {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }
      nav a {
        color: #ccc;
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 0.85rem;
      }
      nav a:hover,
      nav a.active {
        color: white;
        background: rgba(255, 255, 255, 0.1);
        text-decoration: none;
      }
      main {
        min-height: 70vh;
        padding: 40px 0;
      }
      footer {
        background: #1a1a2e;
        color: #999;
        padding: 24px 0;
        text-align: center;
        font-size: 0.85rem;
      }
      .ad-slot {
        background: #f0f0f0;
        border: 1px dashed #ccc;
        padding: 20px;
        text-align: center;
        margin: 24px 0;
        min-height: 90px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #999;
        font-size: 0.8rem;
      }
      .hero {
        text-align: center;
        padding: 60px 20px;
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
        color: white;
        border-radius: 12px;
        margin-bottom: 40px;
      }
      .hero h1 {
        font-size: 2.4rem;
        margin-bottom: 16px;
      }
      .hero p {
        font-size: 1.15rem;
        opacity: 0.9;
        max-width: 600px;
        margin: 0 auto;
      }
      .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 24px;
        margin: 32px 0;
      }
      .card {
        background: white;
        border-radius: 8px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: transform 0.2s;
      }
      .card:hover {
        transform: translateY(-2px);
      }
      .card h2 {
        font-size: 1.3rem;
        margin-bottom: 8px;
        color: #1a1a2e;
      }
      .card p {
        color: #555;
        font-size: 0.95rem;
      }
      @media (max-width: 640px) {
        .hero h1 {
          font-size: 1.6rem;
        }
        .card-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <a class="logo" href={`/${lang}/`}><slot name="logo">Site</slot></a>
        <nav>
          {locales.map((loc) => {
            const path = currentPath.replace(`/${lang}/`, `/${loc}/`);
            return (
              <a href={path} class={loc === lang ? 'active' : ''}>
                {langNames[loc]}
              </a>
            );
          })}
        </nav>
      </div>
    </header>
    <main>
      <div class="container">
        <slot />
      </div>
    </main>
    <footer>
      <div class="container">
        <p>&copy; {new Date().getFullYear()} <slot name="footer-name">Site</slot>. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
